.TUXToastProvider-topOutlet { pointer-events: none; flex-direction: column-reverse; align-items: center; padding-top: 4px; display: flex; position: fixed; top: 0px; left: 0px; right: 0px; }

.TUXToastProvider-topOutlet > * + * { margin-bottom: 4px; }

.TUXToastProvider-bottomOutletContainer { pointer-events: none; position: fixed; bottom: 0px; left: 0px; right: 0px; }

.TUXToastProvider-bottomOutlet { pointer-events: none; flex-direction: column; align-items: center; padding-bottom: 4px; display: flex; }

.TUXToastProvider-bottomOutlet > * + * { margin-top: 4px; }

