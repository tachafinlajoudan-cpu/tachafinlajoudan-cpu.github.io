.TUXToastProvider-center-outlet { pointer-events: none; flex-direction: row; justify-content: center; align-items: center; width: 100%; height: 100%; display: flex; position: fixed; top: 0px; left: 0px; }

.TUXToast { opacity: 1; pointer-events: auto; justify-content: center; transition: opacity 0.2s ease-out; display: flex; }

.TUXToast--top--entered { animation: 0.2s ease-in 0s 1 normal none running TUXToast-top-enter; }

.TUXToast--top--exiting { opacity: 0; }

.TUXToast--bottom--entered { animation: 0.2s ease-in 0s 1 normal none running TUXToast-bottom-enter; }

.TUXToast--bottom--exiting { opacity: 0; }

.TUXToast--center--entered { animation: 0.2s linear 0s 1 normal none running TUXToast-center-enter; }

.TUXToast--center--exiting { animation: 0.2s linear 0s 1 normal none running TUXToast-center-exit; }

@keyframes TUXToast-top-enter { 
  0% { opacity: 0; transform: translateY(-100%); }
  100% { opacity: 1; transform: translateY(0%); }
}

@keyframes TUXToast-bottom-enter { 
  0% { opacity: 0; transform: translateY(100%); }
  100% { opacity: 1; transform: translateY(0%); }
}

@keyframes TUXToast-center-enter { 
  0% { opacity: 0; scale: 0.8; }
  100% { opacity: 1; scale: 1; }
}

@keyframes TUXToast-center-exit { 
  0% { opacity: 1; scale: 1; }
  100% { opacity: 0; scale: 0.8; }
}

